# FinSight Environment Configuration Template

# Google Drive API Settings
# The URL of the folder to scan for receipts
DRIVE_FOLDER_URL=https://www.googleapis.com/drive/v3/folders/YOUR_FOLDER_ID

# JSON content of your Google Service Account Key
SERVICE_ACCOUNT_JSON={"type": "service_account", ...}

# OCR Engine Settings
# Path to the Python executable (usually in the venv)
PYTHON_EXECUTABLE=src/main/resources/scripts/venv/bin/python3
# Path to the OCR processing script
OCR_SCRIPT_PATH=src/main/resources/scripts/trocr_processor.py
# HuggingFace cache location
HF_HOME=src/main/resources/scripts/hf_cache

# Database Settings
SPRING_DATASOURCE_URL=jdbc:libsql:finsight.db

# Frontend Settings
NEXT_PUBLIC_API_URL=http://localhost:8080
